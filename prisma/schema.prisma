generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Country {
    id              Int     @id @default(autoincrement())
    flag            String
    name            String  @unique
    capital         String  @unique
    continent       String
    languageSpeaked String
    exists          Boolean @default(true)

    @@map("Countries")
}
